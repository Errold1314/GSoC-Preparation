#include <iostream
#include <string>
#include <vector>

using namespace std;

/**
 * * This workflow follows the industry-standard process: 
 * Fork -> Clone -> Branch -> Commit -> Push -> Pull Request.
 */
class GitHubWorkflow {
public:
    /**
     * @brief Executes the sequence of git commands required to contribute code.
     */
    void execute() {
        cout << "--- Starting Open Source Workflow ---" << endl;
        
        // Step 1: Forking creates a personal copy of the repository on GitHub.
        step("1. Fork the Repository", "Copying project to your account...");
        
        // Step 2: Clone the repository to your local development environment.
        step("2. Clone", "git clone https://github.com/your-username/repo.git");
        
        // Step 3: Create a feature branch to keep the main branch clean and stable.
        step("3. Create Branch", "git checkout -b my-feature");
        
        // Simulating the local coding cycle
        cout << "[Development] Writing code and running local unit tests..." << endl;
        
        // Step 4: Stage and commit changes. Use meaningful, polite commit messages.
        step("4. Stage & Commit", "git add . && git commit -m 'feat: add user profile'");
        
        // Step 5: Push your branch to your remote fork.
        step("5. Push", "git push origin feature-user-profile");
        
        cout << "\n--- Workflow Complete: Ready to open PR on GitHub! ---" << endl;
        cout << "Note: Visit the original repository on GitHub to initiate your Pull Request." << endl;
    }

private:
    /**
     * @brief Helper function to print steps in the workflow clearly.
     * @param name Title of the workflow step.
     * @param action The specific Git command to be executed.
     */
    void step(string name, string action) {
        cout << "\n[Step] " << name << endl;
        cout << ">> " << action << endl;
    }
};

int main() {
    GitHubWorkflow workflow;
    workflow.execute();
    return 0;
}
